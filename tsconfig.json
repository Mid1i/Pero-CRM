{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "allowJs": true,
    "noImplicitAny": false,

    /* Aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/assets/*": ["./src/assets/*"],
      "@/blocks/*": ["./src/blocks/*"],
      "@/components/*": ["./src/components/*"],
      "@/composables/*": ["./src/composables/*"],
      "@/helpers/*": ["./src/helpers/*"],
      "@/layouts/*": ["./src/layouts/*"],
      "@/plugins/*": ["./src/plugins/*"],
      "@/router/*": ["./src/router/*"],
      "@/types/*": ["./src/types/*"],
      "@/views/*": ["./src/views/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue", "src/plugins/chartsCallbacks.js", "src/composables/topItemsAndUsers.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
